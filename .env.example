# ============================================
# Payment Gateway — Environment Variables
# ============================================

# Node
NODE_ENV=development

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://pguser:pgpassword@localhost:5432/payment_gateway
DB_USER=pguser
DB_PASSWORD=pgpassword
DB_NAME=payment_gateway
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── API Key Encryption ───────────────────────
API_KEY_ENCRYPTION_SECRET=your-api-key-encryption-secret-change-in-production

# ── HMAC ──────────────────────────────────────
HMAC_SECRET=your-hmac-secret-change-in-production

# ── Service Ports ─────────────────────────────
MERCHANT_SERVICE_PORT=3001
PAYMENT_GATEWAY_PORT=3002
BANK_SIMULATOR_PORT=3003
SETTLEMENT_SERVICE_PORT=3004
DASHBOARD_PORT=3000

# ── Service URLs (for inter-service calls) ───
MERCHANT_SERVICE_URL=http://localhost:3001
PAYMENT_GATEWAY_URL=http://localhost:3002
BANK_SIMULATOR_URL=http://localhost:3003
SETTLEMENT_SERVICE_URL=http://localhost:3004

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_MERCHANT_RPM=100
RATE_LIMIT_PUBLIC_RPM=20

# ── Settlement ────────────────────────────────
GATEWAY_FEE_PERCENTAGE=2.0
GST_PERCENTAGE=18.0
SETTLEMENT_CRON=0 2 * * *

# ── Webhook ───────────────────────────────────
WEBHOOK_MAX_RETRIES=8
WEBHOOK_BASE_DELAY_MS=1000

# ── Prometheus ────────────────────────────────
PROMETHEUS_PORT=9090

# ── Logging ───────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json
