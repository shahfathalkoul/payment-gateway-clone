// =============================================================================
// Payment Gateway — Prisma Schema
// =============================================================================
// Provider : PostgreSQL
// Models   : 16 (User, RefreshToken, Merchant, ApiKey, Customer, Payment,
//             PaymentAttempt, Transaction, Refund, Webhook, WebhookEvent,
//             Settlement, Balance, IdempotencyKey, AuditLog, OutboxEvent)
// Enums    : 13
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum PaymentStatus {
  CREATED
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  RUPAY
  DISCOVER
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum RefundStatus {
  CREATED
  PENDING
  PROCESSED
  FAILED
}

enum RefundType {
  FULL
  PARTIAL
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WebhookEventType {
  PAYMENT_CREATED
  PAYMENT_AUTHORIZED
  PAYMENT_CAPTURED
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  REFUND_CREATED
  REFUND_PROCESSED
  REFUND_FAILED
  SETTLEMENT_COMPLETED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ApiKeyType {
  LIVE
  TEST
}

enum UserRole {
  MERCHANT
  ADMIN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  API_KEY_GENERATED
  API_KEY_ROTATED
  PAYMENT_CREATED
  PAYMENT_CAPTURED
  REFUND_INITIATED
  SETTLEMENT_COMPLETED
}

// =============================================================================
// Models
// =============================================================================

/// Platform user – either a merchant owner or an internal admin.
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(MERCHANT)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  merchant      Merchant?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@map("users")
}

/// Short-lived refresh tokens for JWT rotation.
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

/// Merchant account linked 1-to-1 with a User.
model Merchant {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  businessName  String         @map("business_name")
  businessUrl   String?        @map("business_url")
  logoUrl       String?        @map("logo_url")
  webhookUrl    String?        @map("webhook_url")
  webhookSecret String?        @map("webhook_secret")
  status        MerchantStatus @default(PENDING_VERIFICATION)
  feePercentage Decimal        @default(2.0) @map("fee_percentage") @db.Decimal(5, 4)
  isActive      Boolean        @default(true) @map("is_active")
  metadata      Json?          @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys      ApiKey[]
  payments     Payment[]
  refunds      Refund[]
  webhooks     Webhook[]
  settlements  Settlement[]
  balance      Balance?
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@map("merchants")
}

/// API key for authenticating merchant requests (live / test).
model ApiKey {
  id         String     @id @default(uuid()) @db.Uuid
  merchantId String     @map("merchant_id") @db.Uuid
  keyPrefix  String     @map("key_prefix") @db.VarChar(20)
  keyHash    String     @unique @map("key_hash")
  type       ApiKeyType @default(LIVE)
  label      String     @db.VarChar(100)
  isActive   Boolean    @default(true) @map("is_active")
  lastUsedAt DateTime?  @map("last_used_at")
  expiresAt  DateTime?  @map("expires_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([merchantId])
  @@map("api_keys")
}

/// End-customer making a payment on a merchant's platform.
model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?
  phone     String?
  name      String?
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  payments Payment[]

  @@index([email])
  @@index([phone])
  @@map("customers")
}

/// A payment order. The `id` is application-generated (e.g. pay_xxxxx).
model Payment {
  id             String         @id // prefixed, e.g. pay_xxxxxxxxxxxx
  merchantId     String         @map("merchant_id") @db.Uuid
  customerId     String?        @map("customer_id") @db.Uuid
  orderId        String?        @map("order_id")
  amount         Int            // in smallest currency unit (paise)
  currency       String         @default("INR") @db.VarChar(3)
  status         PaymentStatus  @default(CREATED)
  method         PaymentMethod?
  description    String?
  notes          String?
  metadata       Json?          @default("{}")
  callbackUrl    String?        @map("callback_url")
  idempotencyKey String?        @unique @map("idempotency_key")
  errorCode      String?        @map("error_code")
  errorMessage   String?        @map("error_message")
  version        Int            @default(1) // optimistic locking
  capturedAt     DateTime?      @map("captured_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  merchant     Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  attempts     PaymentAttempt[]
  transactions Transaction[]
  refunds      Refund[]

  @@index([merchantId, status, createdAt])
  @@index([merchantId, createdAt])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

/// Individual payment attempt within a payment (retry / method change).
model PaymentAttempt {
  id               String        @id @default(uuid()) @db.Uuid
  paymentId        String        @map("payment_id")
  method           PaymentMethod
  status           PaymentStatus
  gatewayResponse  Json?         @map("gateway_response")
  bankRef          String?       @map("bank_ref")
  errorCode        String?       @map("error_code")
  errorMessage     String?       @map("error_message")
  processingTimeMs Int?          @map("processing_time_ms")
  createdAt        DateTime      @default(now()) @map("created_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_attempts")
}

/// Double-entry ledger row tracking every monetary movement.
model Transaction {
  id           String          @id @default(uuid()) @db.Uuid
  paymentId    String?         @map("payment_id")
  merchantId   String          @map("merchant_id") @db.Uuid
  settlementId String?         @map("settlement_id")
  type         TransactionType
  amount       Int             // in paise
  currency     String          @default("INR") @db.VarChar(3)
  balanceAfter Int             @map("balance_after")
  description  String?
  createdAt    DateTime        @default(now()) @map("created_at")

  // Relations
  payment    Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  merchant   Merchant    @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  settlement Settlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([merchantId, createdAt])
  @@index([paymentId])
  @@index([settlementId])
  @@map("transactions")
}

/// Refund against a captured payment.
model Refund {
  id           String       @id // prefixed, e.g. rfnd_xxxxxxxxxxxx
  paymentId    String       @map("payment_id")
  merchantId   String       @map("merchant_id") @db.Uuid
  amount       Int          // in paise
  type         RefundType
  status       RefundStatus @default(CREATED)
  reason       String?
  bankRef      String?      @map("bank_ref")
  errorCode    String?      @map("error_code")
  errorMessage String?      @map("error_message")
  processedAt  DateTime?    @map("processed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@index([merchantId])
  @@index([status])
  @@map("refunds")
}

/// Webhook endpoint registered by a merchant.
model Webhook {
  id         String             @id @default(uuid()) @db.Uuid
  merchantId String             @map("merchant_id") @db.Uuid
  url        String
  secret     String
  events     WebhookEventType[] // PostgreSQL array of enum values
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  // Relations
  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  webhookEvents WebhookEvent[]

  @@index([merchantId])
  @@map("webhooks")
}

/// Individual delivery attempt for a webhook event.
model WebhookEvent {
  id               String                @id @default(uuid()) @db.Uuid
  webhookId        String                @map("webhook_id") @db.Uuid
  merchantId       String                @map("merchant_id") @db.Uuid
  eventType        WebhookEventType      @map("event_type")
  payload          Json
  status           WebhookDeliveryStatus @default(PENDING)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(8) @map("max_attempts")
  lastAttemptAt    DateTime?             @map("last_attempt_at")
  nextRetryAt      DateTime?             @map("next_retry_at")
  lastResponseCode Int?                  @map("last_response_code")
  lastResponseBody String?               @map("last_response_body")
  deliveredAt      DateTime?             @map("delivered_at")
  createdAt        DateTime              @default(now()) @map("created_at")

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@index([merchantId, createdAt])
  @@index([status, nextRetryAt])
  @@map("webhook_events")
}

/// Batch settlement for a merchant over a time period.
model Settlement {
  id               String           @id // prefixed, e.g. stl_xxxxxxxxxxxx
  merchantId       String           @map("merchant_id") @db.Uuid
  grossAmount      Int              @map("gross_amount")
  gatewayFee       Int              @map("gateway_fee")
  gst              Int
  netAmount        Int              @map("net_amount")
  transactionCount Int              @default(0) @map("transaction_count")
  status           SettlementStatus @default(PENDING)
  periodStart      DateTime         @map("period_start")
  periodEnd        DateTime         @map("period_end")
  settledAt        DateTime?        @map("settled_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([merchantId, status])
  @@index([status, createdAt])
  @@map("settlements")
}

/// Real-time balance for a merchant (optimistic-locked).
model Balance {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @unique @map("merchant_id") @db.Uuid
  available  Int      @default(0)
  pending    Int      @default(0)
  reserved   Int      @default(0)
  currency   String   @default("INR") @db.VarChar(3)
  version    Int      @default(1) // optimistic locking
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("balances")
}

/// Request-scoped idempotency key to guarantee exactly-once processing.
model IdempotencyKey {
  id            String   @id @default(uuid()) @db.Uuid
  key           String
  merchantId    String   @map("merchant_id") @db.Uuid
  requestPath   String   @map("request_path")
  requestMethod String   @map("request_method") @db.VarChar(10)
  responseCode  Int      @map("response_code")
  responseBody  String   @map("response_body") @db.Text
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([key, merchantId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

/// Immutable audit trail for compliance and debugging.
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String      @map("entity_id")
  action     AuditAction
  actorId    String?     @map("actor_id") @db.Uuid
  changes    Json?
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent")
  requestId  String?     @map("request_id")
  createdAt  DateTime    @default(now()) @map("created_at")

  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Transactional outbox for reliable event publishing (outbox pattern).
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type") @db.VarChar(50)
  aggregateId   String    @map("aggregate_id")
  eventType     String    @map("event_type") @db.VarChar(100)
  payload       Json
  isProcessed   Boolean   @default(false) @map("is_processed")
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([isProcessed, createdAt])
  @@map("outbox_events")
}
